library(fpp3)
library(knitr)
library(e1071)
rm(list = ls())
df <- read.csv("Clean_Monthly_Cycle_Hires.csv")
cycle_data <- df %>%
mutate(Month = yearmonth(Month)) %>%
as_tsibble(index = Month)
cycle_data %>%
has_gaps()
head(cycle_data) %>%
kable(align = 'c')
table_1_stats <- cycle_data %>%
as_tibble() %>% # Drop tsibble format temporarily for standard math
summarise(
N = n(),
Mean = mean(Total_Hires),
Median = median(Total_Hires),
SD = sd(Total_Hires),
Min = min(Total_Hires),
Min_Month = as.character(Month[which.min(Total_Hires)]),
Max = max(Total_Hires),
Max_Month = as.character(Month[which.max(Total_Hires)]),
Skewness = skewness(Total_Hires)
)
View(table_1_stats)
table_1_stats %>%
kable(
digits = 2,
align = 'c',
caption = "Table 1: Descriptive Statistics for Monthly Santander Cycle Hires"
)
cycle_data %>%
autoplot(Total_Hires) +
# Add the grey shaded area for the COVID-19 disruption
annotate(
"rect",
xmin = as.Date("2020-03-01"), xmax = as.Date("2021-04-01"),
ymin = -Inf, ymax = Inf,
alpha = 0.2, fill = "grey50"
) +
# Add a small vertical line for the Sept 2022 shutdown
geom_vline(
xintercept = as.Date("2022-09-01"),
color = "red", linetype = "dashed", size = 0.5
) +
labs(
title = "Total Monthly Santander Cycle Hires in London (Aug 2010 - Mar 2026)",
subtitle = "Grey shading indicates COVID-19 period; red dashed line marks Sep 2022 system shutdown",
x = "Year",
y = "Total Hires"
) +
theme(plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5))
