# Print lambda for the report
print(paste("The chosen lambda is:", lambda))
# 2. Apply Box-Cox transformation (with lambda = 0) and plot
cycle_data %>%
autoplot(box_cox(Total_Hires, lambda)) +
labs(
title = "Log-Transformed Monthly Hires (Box-Cox, lambda = 0)",
subtitle = "A natural log transformation successfully stabilises the variance",
x = "Year",
y = "Log(Hires)"
) +
theme(
plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5)
)
lambda <- 0
# Print lambda for the report
print(paste("The chosen lambda is:", lambda))
# 2. Apply Box-Cox transformation (with lambda = 0) and plot
cycle_data %>%
autoplot(box_cox(Total_Hires, lambda)) +
scale_x_yearmonth(date_breaks = "1 year", date_labels = "%Y") +
labs(
title = "Log-Transformed Monthly Hires (Box-Cox, lambda = 0)",
subtitle = "A natural log transformation successfully stabilises the variance",
x = "Year",
y = "Log(Hires)"
) +
theme(
plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5)
)
cycle_data <- cycle_data %>%
mutate(Transformed_Hires = box_cox(Total_Hires, lambda))
cycle_data %>%
model(
classical_decomposition(Transformed_Hires, type = "additive")
) %>%
components() %>%
autoplot() +
labs(
title = "Figure 4: Classical Additive Decomposition",
subtitle = "Components of the Log-Transformed series",
x = "Year"
) +
theme(
plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5)
)
cycle_data %>%
model(
classical_decomposition(Transformed_Hires, type = "additive")
) %>%
components() %>%
autoplot() +
scale_x_yearmonth(date_breaks = "1 year", date_labels = "%Y") +
labs(
title = "Classical Additive Decomposition",
subtitle = "Components of the Log-Transformed series",
x = "Year"
) +
theme(
plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5)
)
library(tseries)
# 1. Extract our new log-transformed series as a numeric vector
log_hires_vec <- cycle_data$Transformed_Hires
# 2. Test 1: Log Series in Levels
print("--- ADF Test: Log Series (Levels) ---")
adf.test(log_hires_vec, alternative = "stationary")
print("--- KPSS Test: Log Series (Levels) ---")
# We use null="Trend" because the data clearly still has a trend
kpss.test(log_hires_vec, null = "Trend")
# 3. Create a First-Differenced Log Series and drop NA values
diff_hires_vec <- diff(log_hires_vec) %>% na.omit()
# 4. Test 2: First-Differenced Log Series
print("--- ADF Test: First-Differenced Series ---")
adf.test(diff_hires_vec, alternative = "stationary")
print("--- KPSS Test: First-Differenced Series ---")
# We use null="Level" because the first difference removes the trend
kpss.test(diff_hires_vec, null = "Level")
# We apply a first difference (d=1) to fix the trend,
# and a seasonal difference (D=1 at lag 12) to fix the rigid summer peaks.
cycle_data %>%
gg_tsdisplay(difference(difference(Transformed_Hires, 12), 1),
plot_type = 'partial', lag_max = 36) +
labs(
title = "Figure 5: ACF and PACF of Differenced Log(Hires)",
subtitle = "First differenced (d=1) and Seasonally differenced (D=1)",
x = "Year",
y = "Differenced Log(Hires)"
) +
theme(
plot.title = element_text(hjust = 0.5),
plot.subtitle = element_text(hjust = 0.5)
)
